# Souk ElKanto Mobile — Environment Configuration
# Copy to .env and adjust values as needed.

# CoreMesh API base URL.
# Android emulator → host localhost:  http://10.0.2.2:3000
# iOS simulator → host localhost:      http://localhost:3000
# Physical device → your machine LAN IP: http://192.168.x.x:3000
API_BASE_URL=http://10.0.2.2:3000

# Tenant identifier (sent as x-tenant-id header)
TENANT_ID=kanto
