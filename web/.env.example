# ──────────────────────────────────────────────────────────────
# Souk ElKanto (web) — environment template
# Copy to `.env.local` and adjust. NEVER commit `.env.local`.
# ──────────────────────────────────────────────────────────────

# Base URL of CoreMesh as seen from the BROWSER.
#   Dev:   leave blank so `/api/*` requests hit the FE origin and Next's dev
#          server proxies them to :3000 (avoids CORS preflight).
#   Prod:  leave blank so calls hit `/api/v1/*` on the FE origin and the
#          Vercel rewrite in vercel.json forwards to https://api.madinatyai.com.
NEXT_PUBLIC_API_BASE=

# Base URL of CoreMesh as seen from the Next.js SERVER (SSR + Route
# Handlers + middleware). Always absolute since Node fetch needs one.
#   Dev:   http://localhost:3000
#   Prod:  https://api.madinatyai.com  (or your Fly app URL)
CORE_MESH_URL=http://localhost:3000

# Tenant this frontend talks to (sent as x-tenant-id on every request).
NEXT_PUBLIC_TENANT_ID=kanto

# Set to "1" to show the "Dev mode: use 000000" hint on the auth pages.
# OFF (or anything other than "1") in production.
NEXT_PUBLIC_AUTH_DEV_HINT=0

# Environment label, surfaced to the FE (used by the staging banner per R-16).
#   development | staging | production
NEXT_PUBLIC_ENV=development

# ── Observability (R-12, optional) ─────────────────────────────
# Sentry browser DSN. Leave blank to disable Sentry on the FE.
NEXT_PUBLIC_SENTRY_DSN=
