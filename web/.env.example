# ──────────────────────────────────────────────────────────────
# Souk ElKanto (web) — environment template
# Copy to `.env.local` and adjust. NEVER commit `.env.local`.
# ──────────────────────────────────────────────────────────────

# Base URL of the CoreMesh backend API gateway.
# The backend MUST be healthy (GET /api/v1/health -> 200) before `npm run dev`.
NEXT_PUBLIC_API_BASE=http://localhost:3000

# Tenant this frontend talks to (sent as x-tenant-id on every request).
# Hard-coded in src/lib/api.ts today; exposed here for visibility / future use.
NEXT_PUBLIC_TENANT_ID=kanto
